{
  "name": "@plugin-web-update-notification/webpack",
  "type": "module",
  "version": "2.0.2",
  "description": "Webpack plugin for detect web page updates and notify.",
  "author": "Utopia",
  "license": "MIT",
  "homepage": "https://github.com/GreatAuk/plugin-web-update-notification",
  "repository": {
    "type": "git",
    "url": "https://github.com/GreatAuk/plugin-web-update-notification",
    "directory": "packages/vite-plugin"
  },
  "bugs": {
    "url": "https://github.com/GreatAuk/plugin-web-update-notification/issues"
  },
  "keywords": [
    "webpack",
    "webpack-plugin",
    "@plugin-web-update-notification/webpack",
    "web-update-notification"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": {
        "require": "./dist/index.d.cts",
        "import": "./dist/index.d.mts"
      },
      "require": "./dist/index.cjs",
      "import": "./dist/index.mjs"
    }
  },
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "tsdown --watch",
    "build": "tsdown"
  },
  "peerDependencies": {
    "webpack": "^4.0.0 || ^5.0.0"
  },
  "dependencies": {
    "@plugin-web-update-notification/core": "workspace:*"
  },
  "devDependencies": {
    "webpack": "^5.0.0"
  }
}
